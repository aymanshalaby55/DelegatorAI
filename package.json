{
  "name": "delegator-ai",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "type": "module",
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "cd apps/api/app && uv run uvicorn main:app --reload --port 4040",
    "dev": "tmux new-session \\; send-keys 'npm run dev:web' Enter \\; split-window -h \\; send-keys 'npm run dev:api' Enter",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "concurrently": "^8.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
