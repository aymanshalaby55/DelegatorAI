{
  "name": "delegator-ai",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "type": "module",
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "cd apps/api && uv run uvicorn main:app --reload --port 8000",
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
